return () => {
          };
    
}, [vidioEnabled]); // ⭐依赖 videoEnabled 



  

  
// ⭐首次点击「开启背景影片」时触发  

 function handleEnableVideo() {
    setVideoEnabbled(true);
 }


 
return (
 <>
        {/* Canvas粒子动画 —秒开 */ }
        <canvas
 
         ref={canvasRf}
         style={{
            position:'fixed',
          inset :0,
          width:'100vw',

           height:'100vh',

