{
  "buildCommand": "npm install && npm install --prefix web && npm run --prefix web build:web",
  "outputDirectory": "web/dist",
  "framework": null,
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
