{
  "buildCommand": "npm install --prefix ./web && npm run build --prefix ./web",
  "outputDirectory": "web/dist",
  "regions": ["sin1"],
  "framework": null,
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
