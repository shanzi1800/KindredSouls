{
  "version": 2,
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "installCommand": "npm install && cd api && npm install 2>/dev/null || true",
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs22.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    },
    {
      "src": "/.*",
      "dest": "/dist/index.html"
    }
  ]
}
